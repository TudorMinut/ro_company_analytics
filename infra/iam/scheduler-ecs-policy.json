{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "RunDownloaderTask",
      "Effect": "Allow",
      "Action": "ecs:RunTask",
      "Resource": "arn:aws:ecs:${AWS_REGION}:${AWS_ACCOUNT_ID}:task-definition/ro-company-downloader-task:*"
    },
    {
      "Sid": "PassEcsRoles",
      "Effect": "Allow",
      "Action": "iam:PassRole",
      "Resource": [
        "arn:aws:iam::${AWS_ACCOUNT_ID}:role/ro-company-ecs-task-execution-role",
        "arn:aws:iam::${AWS_ACCOUNT_ID}:role/ro-company-downloader-task-role"
      ]
    }
  ]
}
